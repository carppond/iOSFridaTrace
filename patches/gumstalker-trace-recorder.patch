+{
+  self->trace_recorder = recorder;
+}
+
 void
 gum_stalker_prefetch (GumStalker * self,
                       gconstpointer address,
@@ -2913,6 +2923,23 @@ gum_stalker_iterator_next (GumStalkerIterator * self,
         GUM_CODE_INTERRUPTIBLE);
   }
 
+  /*
+   * Inline trace: emit BLOCK event at block entry.
+   * Uses micro-prolog (~15 insns) instead of PROLOG_FULL (~50+ insns).
+   */
+  if (is_first_instruction &&
+      self->exec_context->stalker->trace_recorder != NULL &&
+      (self->exec_block->flags & GUM_EXEC_BLOCK_USES_EXCLUSIVE_ACCESS) == 0)
+  {
+    GumTraceRecorder * recorder = self->exec_context->stalker->trace_recorder;
+
+    if (gum_trace_recorder_should_trace (recorder, instruction->start))
+    {
+      gum_trace_inline_emit_block (gc->code_writer, recorder,
+          instruction->start, instruction->end);
+    }
+  }
+
   if (insn != NULL)
     *insn = instruction->ci;
 
@@ -2979,6 +3006,46 @@ gum_stalker_iterator_keep (GumStalkerIterator * self)
     gum_exec_block_write_exec_event_code (block, gc, GUM_CODE_INTERRUPTIBLE);
   }
 
+  /*
+   * Inline trace: emit per-instruction events.
+   * Categorize by instruction type: CALL, RET, or EXEC.
+   * Uses micro-prolog for ~3-5x less overhead than PROLOG_FULL.
+   */
+  {
+    GumTraceRecorder * trace_recorder = block->ctx->stalker->trace_recorder;
+
+    if (trace_recorder != NULL &&
+        (block->flags & GUM_EXEC_BLOCK_USES_EXCLUSIVE_ACCESS) == 0 &&
+        gum_trace_recorder_should_trace (trace_recorder,
+            gc->instruction->start))
+    {
+      switch (insn->id)
+      {
+        case ARM64_INS_BL:
+        case ARM64_INS_BLR:
+        case ARM64_INS_BLRAA:
+        case ARM64_INS_BLRAAZ:
+        case ARM64_INS_BLRAB:
+        case ARM64_INS_BLRABZ:
+          gum_trace_inline_emit_call (gc->code_writer, trace_recorder,
+              gc->instruction->start);
+          break;
+
+        case ARM64_INS_RET:
+        case ARM64_INS_RETAA:
+        case ARM64_INS_RETAB:
+          gum_trace_inline_emit_ret (gc->code_writer, trace_recorder,
+              gc->instruction->start);
+          break;
+
+        default:
+          gum_trace_inline_emit_exec (gc->code_writer, trace_recorder,
+              gc->instruction->start);
+          break;
+      }
+    }
+  }
+
   switch (insn->id)
   {
     case ARM64_INS_B:
